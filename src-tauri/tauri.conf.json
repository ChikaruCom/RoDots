{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoDots",
  "version": "0.1.2",
  "identifier": "app.rawdots.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RoDots",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["rdot"],
        "name": "RoDots Document",
        "description": "RoDots document"
      }
    ]
  }
}
